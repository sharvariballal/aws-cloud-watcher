# Port number the Express backend will run on
PORT=

# MongoDB Connection String (e.g. mongodb://localhost:27017/aws_expense_tracker or Atlas connection URI)
MONGODB_URI=

# Secret key used to sign and verify JSON Web Tokens (JWT) for authentication
JWT_SECRET=

# AWS Configuration Parameters
# These are used for AWS Services (SNS, Cost Explorer, Cognito)
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Amazon Cognito Configuration
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=

# Amazon SNS (Simple Notification Service) Topic ARN for dispatching SMS/Email alerts
SNS_TOPIC_ARN=
